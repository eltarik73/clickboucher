# ═══════════════════════════════════════════════
# Klik&Go — Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════

# ── DATABASE ──────────────────────────────────
# PostgreSQL (Railway, Supabase, or local)
#
# IMPORTANT (Vercel serverless): use a pgbouncer-enabled pooled connection for
# DATABASE_URL, otherwise every cold start opens a fresh PG connection and the
# pool saturates under load. DIRECT_DATABASE_URL must point to the same DB
# without pgbouncer — it is used by `prisma migrate deploy` (which requires a
# direct connection for advisory locks / DDL).
#
# Railway pgbouncer example (recommended for Vercel):
#   DATABASE_URL="postgresql://user:password@host:6543/klikgo?pgbouncer=true&connection_limit=1"
#   DIRECT_DATABASE_URL="postgresql://user:password@host:5432/klikgo"
#
# Local dev (no pgbouncer): both URLs can be identical.
DATABASE_URL="postgresql://user:password@localhost:5432/klikgo?schema=public"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/klikgo?schema=public"

# ── AUTH (Clerk) ─────────────────────────────
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
CLERK_WEBHOOK_SECRET="whsec_..."

AUTH_SECRET="change-me-to-a-random-64-char-string"
OTP_EXPIRY_MINUTES=5

# ── TEST MODE ────────────────────────────────
# Server-only — never prefix with NEXT_PUBLIC_* (would leak the secret to the browser bundle).
# Test mode is automatically disabled in production unless ALLOW_TEST_IN_PROD="true".
# Activation flow: GET/POST /api/test-mode/activate?secret=<TEST_SECRET>&role=CLIENT|BOUCHER|ADMIN
# TEST_MODE="true"
# TEST_SECRET="KlikTest2026!"
# ALLOW_TEST_IN_PROD="false"

# ── APP CONFIG ───────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_URL="https://klikandgo.app"
NEXT_PUBLIC_APP_NAME="Klik&Go"
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="klikandgo.app"

# Weight tolerance for products sold by weight (%)
WEIGHT_TOLERANCE_PERCENT=10

# How long a last-minute offer reservation is held (minutes)
LAST_MINUTE_HOLD_MINUTES=10

# ── PAYMENT ──────────────────────────────────
# "mock" (default) or "stripe" (Stripe not implemented yet — placeholder)
PAYMENT_PROVIDER="mock"
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── NOTIFICATIONS ────────────────────────────
# "stub" (default) or "twilio"
NOTIFICATION_PROVIDER="stub"
RESEND_API_KEY="re_..."

# Required when NOTIFICATION_PROVIDER=twilio
# TWILIO_ACCOUNT_SID="AC..."
# TWILIO_AUTH_TOKEN="..."
# TWILIO_PHONE_NUMBER="+33..."
# TWILIO_WHATSAPP_NUMBER="whatsapp:+33..."

# ── STORAGE (Vercel Blob) ────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ── AI ───────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
REPLICATE_API_TOKEN="r8_..."

# Image search (web gratuite)
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=

# ── RATE LIMITING / CACHE (Upstash Redis) ────
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="..."

# ── MONITORING (Sentry) ──────────────────────
# When set, sentry.{client,server,edge}.config.ts initialise the SDK.
# Leave empty to completely disable Sentry.
SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""

# ── CRON ─────────────────────────────────────
# Secret to authenticate cron endpoints (Vercel cron)
CRON_SECRET="your-cron-secret"

# ── DEPLOYMENT ───────────────────────────────
# NODE_ENV=production
