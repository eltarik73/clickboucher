{
  "name": "clickboucher",
  "version": "0.1.0",
  "private": true,
  "description": "Klik&Go — Click & Collect marketplace for halal butcher shops in France. https://klikandgo.app",
  "homepage": "https://klikandgo.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/eltarik73/clickboucher.git"
  },
  "keywords": [
    "klikandgo",
    "klik-and-go",
    "boucherie-halal",
    "click-and-collect",
    "halal",
    "viande-halal",
    "marketplace",
    "nextjs"
  ],
  "scripts": {
    "postinstall": "prisma generate && (husky 2>/dev/null || true)",
    "dev": "next dev",
    "build": "prisma generate && node scripts/prisma-migrate-prod-only.mjs && next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\" \"prisma/**/*.prisma\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,md}\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prospect": "tsx scripts/prospect-scraper.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{css,md,json,yml}": [
      "prettier --write"
    ]
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@clerk/localizations": "^3.35.3",
    "@clerk/nextjs": "^6.37.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.0.2",
    "@sentry/nextjs": "^10.49.0",
    "@types/dompurify": "^3.0.5",
    "@types/leaflet": "^1.9.21",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.0",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^6.0.78",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "dompurify": "^3.3.1",
    "html5-qrcode": "^2.3.8",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.378.0",
    "next": "^14.2.0",
    "node-cron": "^4.2.1",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-leaflet": "^4.2.1",
    "recharts": "^3.7.0",
    "replicate": "^1.4.0",
    "resend": "^6.9.1",
    "sharp": "^0.34.5",
    "sonner": "^1.4.0",
    "stripe": "^22.1.0",
    "svix": "^1.84.1",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "web-push": "^3.6.7",
    "zod": "^3.23.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^15.5.2",
    "postcss": "^8.4.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "prisma": "^6.19.2",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ]
}
